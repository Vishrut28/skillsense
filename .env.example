# SkillSense — Environment Variables
# Copy this file to .env and fill in ONE of the API keys below.
#
# Option A: Anthropic Claude (best quality, ~$5 free credit on signup)
# Get key at: https://console.anthropic.com
VITE_ANTHROPIC_KEY=

# Option B: Google Gemini (completely free, 15 req/min, no credit card)
# Get key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_KEY=

# The app auto-detects which key is set.
# If VITE_ANTHROPIC_KEY is set → uses Claude Sonnet 4
# If only VITE_GEMINI_KEY is set → uses Gemini 2.0 Flash
